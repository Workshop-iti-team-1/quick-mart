# ========================================
# CoreData (Local Test Databases)
# ========================================
# Ignore local SQLite files generated during simulation/testing.
# NOTE: If you are shipping a pre-populated .sqlite seed file
# in your app bundle, explicitly track it using !YourSeedFile.sqlite
*.sqlite
*.sqlite-shm
*.sqlite-wal

# ========================================
# 🔒 Secrets & Configuration
# ========================================
# Ignore all variations of the real Config file
Config.swift
Config.xcconfig
Config.plist
Config.json
Config.local.xcconfig

# Explicitly track the temporary/template configuration files
!tempConfig.swift
!tempConfig.xcconfig
!tempConfig.plist
!tempConfig.json

*.agentsQuickMartDebug.entitlements
